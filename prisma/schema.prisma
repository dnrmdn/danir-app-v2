generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ======================
 * USER
 * ======================
 */
model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  sessions Session[]
  accounts Account[]
  members  Member[] // USER → MEMBER
  savedLinks SavedLink[] // USER → SAVEDLINK
  mealPlanWeeks MealPlanWeek[]
  financeAccounts FinanceAccount[]
  financeCategories FinanceCategory[]
  financeTags FinanceTag[]
  financeTransactions FinanceTransaction[]
  financeBudgets FinanceBudget[]
  financeGoals FinanceGoal[]

  @@map("user")
}

/**
 * ======================
 * SAVED LINK
 * ======================
 */
model SavedLink {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url         String
  title       String
  label       String?
  previewImage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, url])
  @@map("saved_link")
}

enum MealType {
  BREAKFAST
  SNACK
  LUNCH
  DINNER
}

model MealPlanWeek {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries MealPlanEntry[]

  @@unique([userId, weekStart])
  @@map("meal_plan_week")
}

model MealPlanEntry {
  id        Int      @id @default(autoincrement())
  weekId    Int
  week      MealPlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayIndex  Int
  mealType  MealType
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekId, dayIndex, mealType, sortOrder])
  @@map("meal_plan_entry")
}

enum FinanceAccountType {
  CASH
  BANK
  EWALLET
}

enum FinanceTransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum FinanceTransferDirection {
  IN
  OUT
}

enum FinanceCategoryKind {
  INCOME
  EXPENSE
}

model FinanceAccount {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           FinanceAccountType
  currency       String
  initialBalance Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions FinanceTransaction[]
  transferCounterpartTransactions FinanceTransaction[] @relation("finance_transfer_other_account")

  @@unique([userId, name])
  @@map("finance_account")
}

model FinanceCategory {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  kind      FinanceCategoryKind
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FinanceTransaction[]
  budgets      FinanceBudget[]

  @@unique([userId, name, kind])
  @@map("finance_category")
}

model FinanceTag {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionTags FinanceTransactionTag[]

  @@unique([userId, name])
  @@map("finance_tag")
}

model FinanceTransaction {
  id            Int      @id @default(autoincrement())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     Int
  account       FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type          FinanceTransactionType
  transferDirection FinanceTransferDirection?
  otherAccountId Int?
  otherAccount   FinanceAccount? @relation("finance_transfer_other_account", fields: [otherAccountId], references: [id], onDelete: SetNull)
  amount        Decimal
  currency      String
  date          DateTime
  note          String?
  categoryId    Int?
  category      FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transferGroup String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tags FinanceTransactionTag[]

  @@index([userId, date])
  @@map("finance_transaction")
}

model FinanceTransactionTag {
  id            Int @id @default(autoincrement())
  transactionId Int
  transaction   FinanceTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         Int
  tag           FinanceTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@map("finance_transaction_tag")
}

model FinanceBudget {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId Int
  category   FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month      String
  currency   String
  limit      Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month, currency])
  @@map("finance_budget")
}

model FinanceGoal {
  id            Int      @id @default(autoincrement())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  currency      String
  targetAmount  Decimal
  currentAmount Decimal  @default(0)
  targetDate    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("finance_goal")
}

/**
 * ======================
 * SESSION
 * ======================
 */
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

/**
 * ======================
 * ACCOUNT
 * ======================
 */
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

/**
 * ======================
 * VERIFICATION
 * ======================
 */
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

/**
 * ======================
 * MEMBER
 * ======================
 */
model Member {
  id     Int    @id @default(autoincrement())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name          String
  bgColor       String
  taskColor     String
  taskColorDone String
  iconColor     String
  checkColor    String

  tasks        Task[]
  rewardClaims RewardClaim[]
  rewards      Reward[] // MEMBER → REWARD

  createdAt DateTime @default(now())

  @@map("member")
}

/**
 * ======================
 * TASK
 * ======================
 */
model Task {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  label     String
  date      String
  time      String
  completed Boolean  @default(false)
  reward    Int?
  createdAt DateTime @default(now())

  @@map("task")
}

/**
 * ======================
 * REWARD (Milih Member)
 * ======================
 */
model Reward {
  id Int @id @default(autoincrement())

  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  name     String
  minStars Int
  image    String

  claims RewardClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reward")
}

/**
 * ======================
 * REWARD CLAIM (riwayat klaim reward oleh member)
 * ======================
 */
model RewardClaim {
  id Int @id @default(autoincrement())

  memberId Int
  rewardId Int

  member Member @relation(fields: [memberId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])

  claimedAt DateTime @default(now())

  @@map("reward_claim")
}
