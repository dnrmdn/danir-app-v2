generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ======================
 * USER
 * ======================
 */
/**
 * ======================
 * ROLE
 * ======================
 */
enum UserRole {
  USER
  ADMIN
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  username      String?  @unique
  bio           String?
  phone         String?
  location      String?
  role          UserRole @default(USER)
  planType      PlanType @default(PRO_TRIAL)
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  trialStartAt  DateTime? @default(now())
  trialEndAt    DateTime?
  proStartedAt  DateTime?
  subscriptionEndsAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  sessions            Session[]
  accounts            Account[]
  members             Member[] // USER → MEMBER
  savedLinks          SavedLink[] // USER → SAVEDLINK
  mealPlanWeeks       MealPlanWeek[]
  financeAccounts     FinanceAccount[]
  financeCategories   FinanceCategory[]
  financeTags         FinanceTag[]
  financeTransactions FinanceTransaction[]
  financeBudgets      FinanceBudget[]
  financeGoals        FinanceGoal[]
  groceryCategories   GroceryCategory[]

  partnerConnectionsA    PartnerConnection[]    @relation("PartnerUserA")
  partnerConnectionsB    PartnerConnection[]    @relation("PartnerUserB")
  partnerFeatureAccesses PartnerFeatureAccess[]
  paymentRequests        PaymentRequest[]

  @@map("user")
}

/**
 * ======================
 * SAVED LINK
 * ======================
 */
model SavedLink {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url          String
  title        String
  label        String?
  previewImage String?
  connectionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, url])
  @@map("saved_link")
}

enum MealType {
  BREAKFAST
  SNACK
  LUNCH
  DINNER
}

enum PlanType {
  FREE
  PRO_TRIAL
  PRO
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  EXPIRED
  CANCELED
}

model MealPlanWeek {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart    String
  connectionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entries MealPlanEntry[]

  @@unique([userId, weekStart])
  @@map("meal_plan_week")
}

model MealPlanEntry {
  id        Int          @id @default(autoincrement())
  weekId    Int
  week      MealPlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayIndex  Int
  mealType  MealType
  text      String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([weekId, dayIndex, mealType, sortOrder])
  @@map("meal_plan_entry")
}

enum FinanceAccountType {
  CASH
  BANK
  EWALLET
}

enum FinanceTransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum FinanceTransferDirection {
  IN
  OUT
}

enum FinanceCategoryKind {
  INCOME
  EXPENSE
}

model FinanceAccount {
  id             Int                @id @default(autoincrement())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           FinanceAccountType
  currency       String
  initialBalance Decimal            @default(0) @db.Decimal(18, 2)
  balance        Decimal            @default(0) @db.Decimal(18, 2)
  connectionId   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  transferCounterpartTransactions FinanceTransaction[] @relation("finance_transfer_other_account")
  goals                           FinanceGoal[]
  FinanceTransaction              FinanceTransaction[]

  @@unique([userId, name])
  @@map("finance_account")
}

enum FinanceCategoryClassification {
  NEED
  WANT
  INVESTMENT
  SAVING
  DEBT
  TAX
  OTHER
}

model FinanceCategory {
  id             Int                            @id @default(autoincrement())
  userId         String
  user           User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  kind           FinanceCategoryKind
  parentId       Int?
  parent         FinanceCategory?               @relation("FinanceCategoryToParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       FinanceCategory[]              @relation("FinanceCategoryToParent")
  classification FinanceCategoryClassification?
  icon           String?
  color          String?
  isSystem       Boolean                        @default(false)
  connectionId   String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  transactions FinanceTransaction[]
  budgets      FinanceBudget[]

  @@unique([userId, name, kind, parentId])
  @@index([userId, kind])
  @@index([parentId])
  @@map("finance_category")
}

model FinanceTag {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  connectionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactionTags FinanceTransactionTag[]

  @@unique([userId, name])
  @@map("finance_tag")
}

model FinanceTransaction {
  id                Int                       @id @default(autoincrement())
  userId            String
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId         Int
  account           FinanceAccount            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type              FinanceTransactionType
  transferDirection FinanceTransferDirection?
  otherAccountId    Int?
  otherAccount      FinanceAccount?           @relation("finance_transfer_other_account", fields: [otherAccountId], references: [id], onDelete: SetNull)
  amount            Decimal
  currency          String
  date              DateTime
  note              String?
  categoryId        Int?
  category          FinanceCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transferGroup     String?
  connectionId      String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tags FinanceTransactionTag[]

  @@index([userId, date])
  @@map("finance_transaction")
}

model FinanceTransactionTag {
  id            Int                @id @default(autoincrement())
  transactionId Int
  transaction   FinanceTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         Int
  tag           FinanceTag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@map("finance_transaction_tag")
}

model FinanceBudget {
  id           Int             @id @default(autoincrement())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId   Int
  category     FinanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  month        String
  currency     String
  limit        Decimal
  connectionId String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([userId, categoryId, month, currency])
  @@map("finance_budget")
}

model FinanceGoal {
  id            Int             @id @default(autoincrement())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  currency      String
  targetAmount  Decimal
  currentAmount Decimal         @default(0)
  targetDate    DateTime?
  accountId     Int?
  account       FinanceAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  icon          String?
  color         String?
  connectionId  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("finance_goal")
}

/**
 * ======================
 * SESSION
 * ======================
 */
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

/**
 * ======================
 * ACCOUNT
 * ======================
 */
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([userId, providerId])
  @@map("account")
}

/**
 * ======================
 * VERIFICATION
 * ======================
 */
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

/**
 * ======================
 * MEMBER
 * ======================
 */
model Member {
  id     Int    @id @default(autoincrement())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name          String
  bgColor       String
  taskColor     String
  taskColorDone String
  iconColor     String
  checkColor    String

  tasks        Task[]
  rewardClaims RewardClaim[]
  rewards      Reward[] // MEMBER → REWARD

  createdAt DateTime @default(now())

  @@map("member")
}

/**
 * ======================
 * TASK
 * ======================
 */
model Task {
  id       Int    @id @default(autoincrement())
  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  label     String
  date      String
  time      String
  completed Boolean  @default(false)
  reward    Int?
  createdAt DateTime @default(now())

  @@map("task")
}

/**
 * ======================
 * REWARD (Milih Member)
 * ======================
 */
model Reward {
  id Int @id @default(autoincrement())

  memberId Int
  member   Member @relation(fields: [memberId], references: [id])

  name     String
  minStars Int
  image    String

  claims RewardClaim[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reward")
}

/**
 * ======================
 * REWARD CLAIM (riwayat klaim reward oleh member)
 * ======================
 */
model RewardClaim {
  id Int @id @default(autoincrement())

  memberId Int
  rewardId Int

  member Member @relation(fields: [memberId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])

  claimedAt DateTime @default(now())

  @@map("reward_claim")
}

/**
 * ======================
 * PARTNER SHARING
 * ======================
 */
model PartnerConnection {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  status    String // "PENDING", "ACCEPTED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA User @relation("PartnerUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("PartnerUserB", fields: [userBId], references: [id], onDelete: Cascade)

  featureAccess PartnerFeatureAccess[]

  @@unique([userAId, userBId])
  @@map("partner_connection")
}

model PartnerFeatureAccess {
  id           String  @id @default(cuid())
  connectionId String
  userId       String
  feature      String // "TASKS", "MONEY", "MEAL", "LINKS"
  isEnabled    Boolean @default(false)

  connection PartnerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, userId, feature])
  @@map("partner_feature_access")
}

/**
 * ======================
 * GROCERIES NOTE
 * ======================
 */
model GroceryCategory {
  id        Int      @id @default(autoincrement())
  userId    String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items GroceryItem[]

  @@map("grocery_category")
}

model GroceryItem {
  id         Int      @id @default(autoincrement())
  categoryId Int
  name       String
  checked    Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category GroceryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("grocery_item")
}

/**
 * ======================
 * PAYMENT REQUEST
 * (Foundation for QRIS payment confirmation)
 * ======================
 */
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentPlanTarget {
  PRO
}

model PaymentRequest {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceCode   String        @unique @default(cuid())
  planTarget    PaymentPlanTarget
  amount        Decimal       @db.Decimal(18, 2)
  currency      String        @default("IDR")
  paymentMethod String?       // e.g. "QRIS"
  proofImageUrl String?       // uploaded payment proof
  status        PaymentStatus @default(PENDING)
  notes         String?       // admin notes on approve/reject
  reviewedAt    DateTime?
  reviewedBy    String?       // admin user id who reviewed
  submittedAt   DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payment_request")
}
